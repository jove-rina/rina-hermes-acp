{
  "name": "rina-hermes-acp",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.3.2",
  "publisher": "JoveRina",
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-sidebar",
          "title": "%viewsContainers.activitybar.title%",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "hermes-sidebar": [
        {
          "type": "webview",
          "id": "hermesChat",
          "name": "%views.hermesChat.name%",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "hermes.newChat",
        "title": "%commands.hermes.newChat.title%"
      },
      {
        "command": "hermes.openChat",
        "title": "%commands.hermes.openChat.title%"
      },
      {
        "command": "hermes.sendSelection",
        "title": "%commands.hermes.sendSelection.title%"
      },
      {
        "command": "hermes.reloadExtension",
        "title": "%commands.hermes.reloadExtension.title%",
        "icon": "$(debug-restart)"
      },
      {
        "command": "hermes.reloadSession",
        "title": "%commands.hermes.reloadSession.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes.openSettings",
        "title": "%commands.hermes.openSettings.title%",
        "icon": "$(gear)"
      },
      {
        "command": "hermes.checkUpdate",
        "title": "%commands.hermes.checkUpdate.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hermes.openAbout",
        "title": "%commands.hermes.openAbout.title%",
        "icon": "$(info)"
      },
      {
        "command": "hermes.openHelp",
        "title": "%commands.hermes.openHelp.title%",
        "icon": "$(question)"
      },
      {
        "command": "hermes.openFaq",
        "title": "%commands.hermes.openFaq.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hermes.openLogs",
        "title": "%commands.hermes.openLogs.title%",
        "icon": "$(output)"
      },
      {
        "command": "hermes.detectEnvironment",
        "title": "%commands.hermes.detectEnvironment.title%",
        "icon": "$(search)"
      },
      {
        "command": "hermes.detectEnvironmentBusy",
        "title": "%commands.hermes.detectEnvironmentBusy.title%",
        "icon": "$(sync~spin)"
      },
      {
        "command": "hermes.configureEnvironment",
        "title": "%commands.hermes.configureEnvironment.title%",
        "icon": "$(settings-gear)"
      }
    ],
    "submenus": [
      {
        "id": "hermes.reloadMenu",
        "label": "%submenus.hermes.reloadMenu.label%",
        "icon": "$(refresh)"
      },
      {
        "id": "hermes.envMenu",
        "label": "%submenus.hermes.envMenu.label%",
        "icon": "$(wrench)"
      },
      {
        "id": "hermes.moreMenu",
        "label": "%submenus.hermes.moreMenu.label%",
        "icon": "$(ellipsis)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "submenu": "hermes.envMenu",
          "when": "view == hermesChat",
          "group": "navigation@0"
        },
        {
          "submenu": "hermes.reloadMenu",
          "when": "view == hermesChat",
          "group": "navigation@1"
        },
        {
          "submenu": "hermes.moreMenu",
          "when": "view == hermesChat",
          "group": "navigation@2"
        }
      ],
      "hermes.envMenu": [
        {
          "command": "hermes.detectEnvironment",
          "when": "!hermesDetectInProgress",
          "group": "1@1"
        },
        {
          "command": "hermes.detectEnvironmentBusy",
          "when": "hermesDetectInProgress",
          "group": "1@1"
        },
        {
          "command": "hermes.configureEnvironment",
          "when": "!hermesDetectInProgress",
          "group": "1@2"
        }
      ],
      "hermes.reloadMenu": [
        {
          "command": "hermes.reloadExtension",
          "group": "1@1"
        },
        {
          "command": "hermes.reloadSession",
          "group": "1@2"
        }
      ],
      "hermes.moreMenu": [
        {
          "command": "hermes.openSettings",
          "group": "1@1"
        },
        {
          "command": "hermes.checkUpdate",
          "group": "1@2"
        },
        {
          "command": "hermes.openAbout",
          "group": "2@1"
        },
        {
          "command": "hermes.openHelp",
          "group": "2@2"
        },
        {
          "command": "hermes.openFaq",
          "group": "2@3"
        },
        {
          "command": "hermes.openLogs",
          "group": "3@1"
        }
      ],
      "editor/context": [
        {
          "command": "hermes.sendSelection",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "hermes.path": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.path.description%"
        },
        "hermes.cwd": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.cwd.description%"
        },
        "hermes.profile": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.profile.description%"
        },
        "hermes.showThoughts": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.hermes.showThoughts.description%"
        },
        "hermes.showToolCalls": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.hermes.showToolCalls.description%"
        },
        "hermes.contextAttachVisibility": {
          "type": "string",
          "default": "onNewSession",
          "enum": [
            "onNewSession",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "%configuration.hermes.contextAttachVisibility.onNewSession.description%",
            "%configuration.hermes.contextAttachVisibility.always.description%",
            "%configuration.hermes.contextAttachVisibility.never.description%"
          ],
          "description": "%configuration.hermes.contextAttachVisibility.description%"
        },
        "hermes.models": {
          "type": "array",
          "default": [],
          "description": "%configuration.hermes.models.description%",
          "markdownDescription": "%configuration.hermes.models.markdownDescription%",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name"
            ]
          }
        },
        "hermes.defaultModel": {
          "type": "string",
          "default": "",
          "description": "%configuration.hermes.defaultModel.description%"
        },
        "hermes.agents": {
          "type": "array",
          "default": [],
          "description": "%configuration.hermes.agents.description%",
          "markdownDescription": "%configuration.hermes.agents.markdownDescription%",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "profile": {
                "type": "string"
              },
              "cwd": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run generate:webview-protocol && npm run build:webview && tsc -p ./",
    "generate:webview-protocol": "node ./scripts/generate-webview-protocol.mjs",
    "build:webview": "node ./scripts/build-webview.mjs",
    "init:webview": "node ./scripts/init-webview-src.mjs",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node ./scripts/build-webview.mjs --watch",
    "package": "vsce package",
    "test": "node ./out/tests/runTest.js",
    "test:unit": "mocha --ui bdd --color out/tests/suite/*.test.js",
    "test:webview": "vitest run --config vitest.webview.config.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.25.12",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jove-rina/rina-hermes-acp"
  }
}
