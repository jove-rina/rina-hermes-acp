{
  "name": "hermes-agent-chat",
  "displayName": "Hermes Agent Chat",
  "description": "Chat with Hermes Agent directly inside VS Code",
  "version": "0.2.0-beta.1",
  "publisher": "jove-rina",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onView:hermesChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-sidebar",
          "title": "Hermes Agent",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "hermes-sidebar": [
        {
          "type": "webview",
          "id": "hermesChat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "hermes.newChat",
        "title": "Hermes: New Chat"
      },
      {
        "command": "hermes.openChat",
        "title": "Hermes: Open Chat"
      },
      {
        "command": "hermes.sendSelection",
        "title": "Send to Hermes Agent"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hermes.sendSelection",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Hermes Agent Chat",
      "properties": {
        "hermes.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Hermes executable. Leave empty to auto-detect."
        },
        "hermes.cwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for Hermes sessions. Defaults to workspace root."
        },
        "hermes.profile": {
          "type": "string",
          "default": "",
          "description": "Hermes profile name (maps to hermes --profile <name>). Leave empty for default."
        },
        "hermes.agents": {
          "type": "array",
          "default": [],
          "description": "List of named agent configurations for quick switching via the chat UI.",
          "markdownDescription": "List of named agent configurations for quick switching. Each agent can have a different `path`, `profile`, and `cwd`. Example:\n```json\n[\n  { \"name\": \"Default\", \"profile\": \"\" },\n  { \"name\": \"Fast\", \"path\": \"/path/to/hermes\", \"profile\": \"fast\" }\n]\n```",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "profile": { "type": "string" },
              "cwd": { "type": "string" }
            },
            "required": ["name"]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "node ./out/tests/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.28.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jove-rina/hermes-agent-chat"
  }
}
